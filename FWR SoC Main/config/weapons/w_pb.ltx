anim_empty		= empty
anim_reload		= reload_new
anim_reload_empty	= reload_new_empty
anim_draw		= draw
anim_draw_empty		= draw_empty
anim_shoot		= shoot
anim_shot_last		= shoot_last
anim_close		= holster
anim_idle_aim		= idle
anim_idle_sprint	= idle_sprint

;смещения HUD для режима приближения
