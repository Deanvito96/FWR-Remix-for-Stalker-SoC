[wpn_pb]:identity_immunities
GroupControlSection		= spawn_group
discovery_dependency	 	= 
$spawn          		= "weapons\pb"					; option for Level Editor
$npc				= on		; option for Level Editor
$prefetch 			= 8
scheduled       	     	= off              ; option for ALife Simulator
cform           	        = skeleton
class           	        = WP_PM
min_radius      	        = 0
max_radius      	        = 30
description			= enc_weapons1_wpn-pb

ef_weapon_type				= 5

;---DOF-------------------------------------------------------------------------
zoom_dof					= 0.5, 1.0, 180
reload_dof				= 0.0, 0.5, 5, 1.7
;-------------------------------------------------------------------------------

;-----------------------------------------------------------------------------------
holder_range_modifier		= 1.0               ; во сколько раз увеличивается eye_range 
holder_fov_modifier		= 1.0              ; во сколько раз увеличивается eye_fov
;-----------------------------------------------------------------------------------

cost						= 350

ammo_limit			= 120
ammo_current			= 96
ammo_elapsed			= 8

ammo_mag_size			= 8
ammo_class		 	= ammo_9x18_fmj, ammo_9x18_pmm, ammo_9x18_pbp
	
hand_dependence			= 1
single_handed			= 1

slot 				= 1
animation_slot			= 1		; type of the animation that will be used

inv_name			= wpn-pb
inv_name_short			= wpn-pb
inv_weight			= 0.95
	
inv_grid_width			= 2
inv_grid_height			= 1
inv_grid_x			= 15
inv_grid_y			= 6

kill_msg_x			= 80
kill_msg_y			= 154
kill_msg_width			= 49
kill_msg_height			= 22

;-----------------------------------------------------------------------------------
;базовая дисперсия
fire_dispersion_base		= 0.35 	;угол (в градусах) базовой дисперсии оружия (оружия зажатого в тисках)

;отдача
cam_relax_speed         	= 10;0.6	;скорость возврата в исходное положение
cam_dispersion          	= 0.3	;увеличения угла (в градусах) с каждым выстрелом
cam_dispersion_inc		= 0.0	;увеличениe cam_dispersion с каждым выстрелом
cam_dispertion_frac		= 1.0	;ствол будет подыматься на cam_dispersion*cam_dispertion_frac +- cam_dispersion*(1-cam_dispertion_frac)
cam_max_angle			= 20.0	;максимальный угол отдачи
cam_max_angle_horz		= 10.0	;(degree) maximum shot horizontal degree 
cam_step_angle_horz		= 1.5	;(degree) size of step camera moved in horizontal position while shooting

fire_dispersion_condition_factor = 5	;увеличение дисперсии в процентах при максимальном износе 
misfire_probability 		= 0.005	;вероятность осечки при максимальном износе
misfire_condition_k		= 0.05 
condition_shot_dec 		= 0.0003 ;увеличение износа при каждом выстреле
;-----------------------------------------------------------------------------------

direction           	    	= 0, 0, 1
fire_point          	   	= 0.0, 0.104, 0.273

smoke_particles			= weapons\generic_shoot_00

shell_point		 	= 0.0, 0.104, 0.03
shell_dir		 	= 0.0, 0.0, 0.4
shell_particles	 		= weapons\9x18
 
rpm_empty_click 		= 200

PDM_disp_base 			= 1.0
PDM_disp_vel_factor 		= 0.9
PDM_disp_accel_factor 		= 0.9
PDM_crouch	 		= 1.0
PDM_crouch_no_acc 		= 1.0

; ttc
hit_power        		= 0.3
hit_impulse		 	= 56
hit_type 		 	= fire_wound

fire_distance    		= 50
bullet_speed			= 290	;начальная скорость пули
rpm              		= 300
; end ttc

use_aim_bullet			= true		;Поддерживается ли первая суппер пуля
time_to_aim			= 1.0	

hud              	        = wpn_pb_hud
normal           	        = 0, 1, 0
position         	        = -0.021, -0.07, 0.0
orientation      	        = 0, 0, 0

;--STRAP PARAMETERS-----------------------------------------------------------------
visual           		= weapons\pb\wpn_pb.ogf

light_disabled			= true

ph_mass			 	= 1
;cost			 	= 350

;addons
scope_status			= 0
silencer_status			= 1
grenade_launcher_status		= 0

zoom_enabled			= true
zoom_hide_crosshair		= true						;to hide crosshair in zoom 
