;звуки
snd_draw			= weapons\pm_draw
snd_holster			= weapons\generic_holster
snd_shoot					= weapons\pb_shoot
snd_empty			= weapons\generic_empty
snd_reload			= weapons\pm_reload, 0.8
snd_close			= weapons\generic_close

